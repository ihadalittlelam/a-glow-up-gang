# Copy this file to .env.local for local development (never commit .env.local).
# In production, set this same variable in Vercel: Settings > Environment Variables.

# Get this from console.anthropic.com (Manage > API keys). Starts with sk-ant-.
# Without it, the "Personalized notes" section falls back to a plain message
# instead of the LLM-written narrative — the site still builds and works.
ANTHROPIC_API_KEY=
